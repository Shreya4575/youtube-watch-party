# Frontend environment variables (Vite)
# ─────────────────────────────────────────────────────────────────────────────
# LOCAL DEVELOPMENT — backend runs on port 3000
VITE_BACKEND_URL=http://localhost:3000

# ─────────────────────────────────────────────────────────────────────────────
# PRODUCTION — change this to your deployed backend URL before deploying
# e.g. VITE_BACKEND_URL=https://my-backend.onrender.com
