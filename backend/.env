# Backend environment variables
# ─────────────────────────────────────────────────────────────────────────────
# LOCAL DEVELOPMENT
# Copy this file to .env and fill in the values.
# Do NOT commit .env to git.

PORT=3000
FRONTEND_URL=http://localhost:5173

# ─────────────────────────────────────────────────────────────────────────────
# PRODUCTION (when deployed on Render / Railway)
# Set these as environment variables in your deployment dashboard:
#
# PORT          → provided automatically by the platform (don't override)
# FRONTEND_URL  → your Vercel/Netlify frontend URL, e.g. https://my-app.vercel.app
